/* ==========================================================================
   LLM Prompt Queue - Popup Styles
   ========================================================================== */

/* --------------------------------------------------------------------------
   CSS Custom Properties (Light Mode Defaults)
   -------------------------------------------------------------------------- */
:root {
  /* Colors */
  --color-bg-primary: #ffffff;
  --color-bg-secondary: #f5f5f7;
  --color-bg-tertiary: #e8e8ed;
  --color-bg-hover: #f0f0f2;

  --color-text-primary: #1d1d1f;
  --color-text-secondary: #6e6e73;
  --color-text-tertiary: #86868b;
  --color-text-placeholder: #a1a1a6;

  --color-border: #d2d2d7;
  --color-border-light: #e5e5ea;

  /* Status Colors */
  --color-success: #34c759;
  --color-success-bg: #e8f8ec;
  --color-warning: #ff9f0a;
  --color-warning-bg: #fff8e6;
  --color-error: #ff3b30;
  --color-error-bg: #ffebea;
  --color-info: #007aff;
  --color-info-bg: #e6f2ff;
  --color-idle: #8e8e93;
  --color-idle-bg: #f2f2f7;

  /* Interactive */
  --color-primary: #007aff;
  --color-primary-hover: #0056b3;
  --color-primary-active: #004494;
  --color-danger: #ff3b30;
  --color-danger-hover: #d62d24;

  /* Toggle */
  --toggle-bg-off: #e5e5ea;
  --toggle-bg-on: #34c759;
  --toggle-knob: #ffffff;

  /* Shadows */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.08);

  /* Spacing */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;

  /* Border Radius */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-full: 9999px;

  /* Transitions */
  --transition-fast: 150ms ease;
  --transition-normal: 200ms ease;
  --transition-slow: 300ms ease;
}

/* --------------------------------------------------------------------------
   Dark Mode
   -------------------------------------------------------------------------- */
@media (prefers-color-scheme: dark) {
  :root {
    --color-bg-primary: #1c1c1e;
    --color-bg-secondary: #2c2c2e;
    --color-bg-tertiary: #3a3a3c;
    --color-bg-hover: #3a3a3c;

    --color-text-primary: #f5f5f7;
    --color-text-secondary: #a1a1a6;
    --color-text-tertiary: #8e8e93;
    --color-text-placeholder: #636366;

    --color-border: #48484a;
    --color-border-light: #3a3a3c;

    /* Status Colors - adjusted for dark mode */
    --color-success: #30d158;
    --color-success-bg: rgba(48, 209, 88, 0.15);
    --color-warning: #ffd60a;
    --color-warning-bg: rgba(255, 214, 10, 0.15);
    --color-error: #ff453a;
    --color-error-bg: rgba(255, 69, 58, 0.15);
    --color-info: #0a84ff;
    --color-info-bg: rgba(10, 132, 255, 0.15);
    --color-idle: #98989d;
    --color-idle-bg: rgba(152, 152, 157, 0.15);

    /* Interactive */
    --color-primary: #0a84ff;
    --color-primary-hover: #409cff;
    --color-primary-active: #64b5ff;
    --color-danger: #ff453a;
    --color-danger-hover: #ff6961;

    /* Toggle */
    --toggle-bg-off: #636366;
    --toggle-bg-on: #30d158;
    --toggle-knob: #ffffff;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.4);
  }
}

/* --------------------------------------------------------------------------
   Base Styles
   -------------------------------------------------------------------------- */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 14px;
}

body {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 1rem;
  line-height: 1.5;
  color: var(--color-text-primary);
  background-color: var(--color-bg-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* --------------------------------------------------------------------------
   Popup Container
   -------------------------------------------------------------------------- */
.popup-container {
  width: 380px;
  min-height: 500px; /* ENFORCED: Prevents window from jarringly collapsing on empty tabs */
  height: 100vh;
  max-height: 600px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* --------------------------------------------------------------------------
   Header
   -------------------------------------------------------------------------- */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
  background-color: var(--color-bg-primary);
}

.header-title {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  font-size: 0.75rem;
  font-weight: 500;
  background-color: var(--color-idle-bg);
  color: var(--color-idle);
  transition: background-color var(--transition-normal), color var(--transition-normal);
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: currentColor;
  transition: background-color var(--transition-normal);
}

/* Status States */
.status-indicator[data-status="idle"] {
  background-color: var(--color-idle-bg);
  color: var(--color-idle);
}

.status-indicator[data-status="waiting"] {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-indicator[data-status="sending"] {
  background-color: var(--color-info-bg);
  color: var(--color-info);
}

.status-indicator[data-status="active"] {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.status-indicator[data-status="paused"] {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

/* Pulse animation for active states */
.status-indicator[data-status="waiting"] .status-dot,
.status-indicator[data-status="sending"] .status-dot {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* --------------------------------------------------------------------------
   Tabs Navigation
   -------------------------------------------------------------------------- */
.tabs-nav {
  display: flex;
  background-color: var(--color-bg-primary);
  border-bottom: 1px solid var(--color-border-light);
}

.tab-btn {
  flex: 1;
  padding: var(--spacing-sm) var(--spacing-md);
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--color-text-secondary);
  font-weight: 500;
  font-size: 0.875rem;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.tab-btn:hover {
  color: var(--color-text-primary);
  background-color: var(--color-bg-hover);
}

.tab-btn.active {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
}

/* --------------------------------------------------------------------------
   View Sections
   -------------------------------------------------------------------------- */
.view-section {
  display: none;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.view-section.active-view {
  display: flex;
}

/* --------------------------------------------------------------------------
   Site Status
   -------------------------------------------------------------------------- */
.site-status {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-lg);
  background-color: var(--color-bg-secondary);
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
  border-bottom: 1px solid var(--color-border-light);
}

.site-icon {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: var(--color-idle);
  transition: background-color var(--transition-normal);
}

.site-status[data-connected="true"] .site-icon {
  background-color: var(--color-success);
}

.site-status[data-connected="true"] {
  color: var(--color-text-primary);
}

/* --------------------------------------------------------------------------
   Add Prompt Section
   -------------------------------------------------------------------------- */
.add-prompt-section {
  padding: var(--spacing-sm) var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
}

.input-label {
  display: block;
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
}

.prompt-input {
  width: 100%;
  min-height:  44px;
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-family: inherit;
  font-size: 0.875rem;
  line-height: 1.5;
  resize: vertical;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}

.prompt-input::placeholder {
  color: var(--color-text-placeholder);
}

.prompt-input:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.15);
}

.input-hint {
  display: block;
  font-size: 0.6875rem;
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

/* --------------------------------------------------------------------------
   Buttons
   -------------------------------------------------------------------------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-lg);
  border: none;
  border-radius: var(--radius-md);
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: background-color var(--transition-fast), transform var(--transition-fast), opacity var(--transition-fast);
}

.btn:focus {
  outline: none;
  box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.3);
}

.btn:active {
  transform: scale(0.98);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.btn-primary {
  width: 100%;
  background-color: var(--color-primary);
  color: #ffffff;
}

.btn-primary:hover:not(:disabled) {
  background-color: var(--color-primary-hover);
}

.btn-primary:active:not(:disabled) {
  background-color: var(--color-primary-active);
}

.btn-secondary {
  width: 100%;
  background-color: var(--color-bg-tertiary);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
  margin-top: var(--spacing-md);
}

.btn-secondary:hover:not(:disabled) {
  background-color: var(--color-bg-hover);
  border-color: var(--color-primary);
}

.btn-secondary:active:not(:disabled) {
  background-color: var(--color-bg-tertiary);
}

.btn-icon-left {
  margin-right: var(--spacing-xs);
  font-size: 0.75rem;
}

.btn-danger {
  background-color: transparent;
  color: var(--color-danger);
  border: 1px solid var(--color-danger);
}

.btn-danger:hover:not(:disabled) {
  background-color: var(--color-error-bg);
}

.btn-small {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: 0.75rem;
width: auto;
  margin-top: 0;
}

.btn-icon {
  width: 24px;
  height: 24px;
  padding: 0;
  border-radius: var(--radius-sm);
  background-color: transparent;
  color: var(--color-text-tertiary);
  font-size: 1rem;
  line-height: 1;
}

.btn-icon:hover:not(:disabled) {
  background-color: var(--color-bg-hover);
  color: var(--color-text-primary);
}

.btn-icon.btn-delete:hover:not(:disabled) {
  background-color: var(--color-error-bg);
  color: var(--color-danger);
}

/* --------------------------------------------------------------------------
   Settings Section
   -------------------------------------------------------------------------- */
.settings-section {
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
}

.toggle-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-label {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-primary);
  cursor: pointer;
}

.toggle-switch {
  position: relative;
  display: inline-block;
  width: 32px;
  height: 18px;
  cursor: pointer;
}

.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
  position: absolute;
}

.toggle-slider {
  position: absolute;
  inset: 0;
  background-color: var(--toggle-bg-off);
  border-radius: var(--radius-full);
  transition: background-color var(--transition-normal);
}

.toggle-slider::before {
  content: '';
  position: absolute;
  width: 14px;
  height: 14px;
  left: 2px;
  bottom: 2px;
  background-color: var(--toggle-knob);
  border-radius: 50%;
  box-shadow: var(--shadow-sm);
  transition: transform var(--transition-normal);
}

.toggle-switch input:checked + .toggle-slider {
  background-color: var(--toggle-bg-on);
}

.toggle-switch input:checked + .toggle-slider::before {
  transform: translateX(20px);
}

.toggle-switch input:focus + .toggle-slider {
  box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.3);
}

/* --------------------------------------------------------------------------
   Queue Section
   -------------------------------------------------------------------------- */
.queue-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.queue-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  background-color: var(--color-bg-primary);
  border-bottom: 1px solid var(--color-border-light);
}

.queue-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

.queue-count {
  font-weight: 400;
  color: var(--color-text-tertiary);
}

.queue-list {
  flex: 1;
  overflow-y: auto;
  padding: var(--spacing-sm) var(--spacing-lg);
  background-color: var(--color-bg-secondary);
}

/* Custom Scrollbar */
.queue-list::-webkit-scrollbar {
  width: 6px;
}

.queue-list::-webkit-scrollbar-track {
  background: transparent;
}

.queue-list::-webkit-scrollbar-thumb {
  background-color: var(--color-border);
  border-radius: var(--radius-full);
}

.queue-list::-webkit-scrollbar-thumb:hover {
  background-color: var(--color-text-tertiary);
}

/* Empty State */
.queue-empty {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  text-align: center;
  color: var(--color-text-tertiary);
}

.queue-empty[data-empty="true"] {
  display: flex;
}

.queue-empty p {
  margin: 0;
}

.queue-empty-hint {
  font-size: 0.75rem;
  margin-top: var(--spacing-xs) !important;
}

/* --------------------------------------------------------------------------
   Queue Items
   -------------------------------------------------------------------------- */
.queue-item {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  background-color: var(--color-bg-primary);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-md);
  transition: transform var(--transition-fast), opacity var(--transition-fast), box-shadow var(--transition-fast);
  animation: slideIn var(--transition-slow) ease-out;
}

.queue-item:last-child {
  margin-bottom: 0;
}

.queue-item:hover {
  box-shadow: var(--shadow-sm);
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Item leaving animation */
.queue-item.leaving {
  animation: slideOut var(--transition-normal) ease-out forwards;
}

@keyframes slideOut {
  from {
    opacity: 1;
    transform: translateX(0);
  }
  to {
    opacity: 0;
    transform: translateX(20px);
  }
}

.queue-item-number {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  margin-top: 2px;
  margin-top: 2px;
  background-color: var(--color-bg-tertiary);
  color: var(--color-text-secondary);
  font-size: 0.6875rem;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.queue-item-content {
  flex: 1;
  min-width: 0;
}

.queue-item-text {
  display: block;
  font-size: 0.95rem;
  line-height: 1.4;
  color: var(--color-text-primary);
  word-break: break-word;
  white-space: pre-wrap;
  padding-right: 8px;
}

.queue-item-actions {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
  margin-top: 2px;
  margin-top: 2px;
}

.queue-item-reorder {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.btn-reorder {
  width: 20px;
  height: 16px;
  padding: 0;
  border-radius: 2px;
  background-color: transparent;
  color: var(--color-text-tertiary);
  font-size: 0.625rem;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-reorder:hover:not(:disabled) {
  background-color: var(--color-bg-hover);
  color: var(--color-text-primary);
}

/* --------------------------------------------------------------------------
   Library Section
   -------------------------------------------------------------------------- */
.library-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.library-header {
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
  background-color: var(--color-bg-primary);
}

.library-title {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
}

.library-list {
  flex: 1;
  overflow-y: auto;
  padding: var(--spacing-sm) var(--spacing-lg);
  background-color: var(--color-bg-secondary);
}

.library-list::-webkit-scrollbar {
  width: 6px;
}
.library-list::-webkit-scrollbar-track {
  background: transparent;
}
.library-list::-webkit-scrollbar-thumb {
  background-color: var(--color-border);
  border-radius: var(--radius-full);
}

/* Library Cards */
.library-chain-card {
  background-color: var(--color-bg-primary);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
}

.library-chain-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-xs);
}

.library-chain-title {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--color-text-primary);
  word-break: break-word;
  white-space: pre-wrap;
  padding-right: 8px;
}

.library-chain-date {
  font-size: 0.6875rem;
  color: var(--color-text-tertiary);
  white-space: nowrap;
}

.library-chain-meta {
  font-size: 0.75rem;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}

.library-chain-actions {
  display: flex;
  gap: var(--spacing-sm);
  align-items: center;
}

.library-chain-actions .btn {
  flex: 1;
  min-width: fit-content;
}

.library-chain-actions .btn-icon {
  flex: 0 0 auto;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Dedicated Library Empty State */
.library-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  min-height: 200px;
  text-align: center;
  color: var(--color-text-tertiary);
}

.library-empty-state .empty-icon {
  font-size: 2.5rem;
  margin-bottom: var(--spacing-sm);
  opacity: 0.6;
}

.library-empty-state .empty-title {
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.library-empty-state .empty-hint {
  font-size: 0.8125rem;
}

/* --------------------------------------------------------------------------
   Status Message Toast
   -------------------------------------------------------------------------- */
.status-message {
  position: absolute;
  bottom: var(--spacing-lg);
  left: var(--spacing-lg);
  right: var(--spacing-lg);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
  font-size: 0.8125rem;
  font-weight: 500;
  text-align: center;
  background-color: var(--color-bg-tertiary);
  color: var(--color-text-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(10px);
  opacity: 0;
  transition: transform var(--transition-normal), opacity var(--transition-normal);
  z-index: 100;
}

.status-message:not([hidden]) {
  transform: translateY(0);
  opacity: 1;
}

.status-message[data-type="success"] {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.status-message[data-type="error"] {
  background-color: var(--color-error-bg);
  color: var(--color-error);
}

.status-message[data-type="info"] {
  background-color: var(--color-info-bg);
  color: var(--color-info);
}

.status-message[data-type="warning"] {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

/* --------------------------------------------------------------------------
   Utility Classes
   -------------------------------------------------------------------------- */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
/* --------------------------------------------------------------------------
   Execution Footer
   -------------------------------------------------------------------------- */
.execution-footer {
  margin-top: auto;
  border-top: 1px solid var(--color-border-light);
  border-bottom: none;
  position: sticky;
  bottom: 0;
  background-color: var(--color-bg-primary);
  z-index: 10;
  box-shadow: 0 -4px 6px -4px rgba(0, 0, 0, 0.05);
}

/* --------------------------------------------------------------------------
   Execution Footer
   -------------------------------------------------------------------------- */
.execution-footer {
  margin-top: auto;
  border-top: 1px solid var(--color-border-light);
  background-color: var(--color-bg-primary);
  z-index: 10;
  flex-shrink: 0;
  box-shadow: 0 -8px 16px rgba(0, 0, 0, 0.05);
}

/* --------------------------------------------------------------------------
   Execution Footer
   -------------------------------------------------------------------------- */
.execution-footer {
  margin-top: auto;
  border-top: 1px solid var(--color-border-light);
  background-color: var(--color-bg-primary);
  z-index: 10;
  flex-shrink: 0;
  box-shadow: 0 -8px 16px rgba(0, 0, 0, 0.05);
}


/* --------------------------------------------------------------------------
   Variable Injection Modal
   -------------------------------------------------------------------------- */
.modal-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 1;
  transition: opacity var(--transition-normal);
}

.modal-overlay[hidden] {
  display: none;
  opacity: 0;
}

.modal-content {
  background-color: var(--color-bg-primary);
  padding: var(--spacing-xl);
  border-radius: var(--radius-lg);
  width: 88%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  border: 1px solid var(--color-border-light);
  display: flex;
  flex-direction: column;
}

.variable-input-group {
  margin-bottom: var(--spacing-md);
}

.variable-input-group:last-child {
  margin-bottom: 0;
}


/* --------------------------------------------------------------------------
   Premium Prompt Footer
   -------------------------------------------------------------------------- */
.prompt-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6px;
  margin-bottom: var(--spacing-md);
  font-size: 0.7rem;
  color: var(--color-text-tertiary);
  user-select: none;
}

.prompt-hint-left {
  display: flex;
  align-items: center;
  gap: 4px;
}

.prompt-hint-left code {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-light);
  padding: 2px 4px;
  border-radius: 4px;
  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
  color: var(--color-text-secondary);
  font-size: 0.9em;
  font-weight: 500;
}

.prompt-hint-right {
  display: flex;
  align-items: center;
  gap: 3px;
}

.prompt-hint-right kbd {
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-bottom-width: 2px;
  padding: 1px 4px;
  border-radius: 4px;
  font-family: system-ui, -apple-system, sans-serif;
  font-weight: 600;
  color: var(--color-text-secondary);
  font-size: 0.85em;
  line-height: 1;
}


/* --------------------------------------------------------------------------
   Inline Edit Mode
   -------------------------------------------------------------------------- */
.queue-item-edit-input {
  width: 100%;
  min-height: 50px;
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: 0.95rem;
  line-height: 1.4;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  resize: vertical;
  box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.15);
  outline: none;
  margin-top: -2px;
  margin-left: -4px;
}

/* --- INJECTED: Active Processing State --- */
.queue-item.active-processing {
  border-color: var(--color-primary);
  background-color: var(--color-info-bg);
  box-shadow: 0 0 0 1px var(--color-primary);
  transform: none !important;
}
.queue-item.active-processing .queue-item-number {
  background-color: var(--color-primary);
  color: #ffffff;
  animation: pulse 1.5s ease-in-out infinite;
}
.queue-item.active-processing .queue-item-drag-handle,
.queue-item.active-processing .queue-item-actions {
  opacity: 0.3;
  pointer-events: none;
}
